block vars
doctype html

html(lang='en')
  head
    - const meta = site[pageKey] || {};
    meta(charset='UTF-8')
    meta(name='viewport', content='width=device-width, initial-scale=1.0')
    meta(name='description', content=meta.description || 'Default Site Description')
    meta(property='og:image', content=meta.ogImage || site.global.ogImage)
    link(rel='stylesheet', href='/src/styles/global.css')
    title #{ meta.title || 'Welcome' } | #{ site.global.name }
    script(
      src="https://hma-chat-bot.vercel.app/widget/chat-widget.js" 
      data-chatbot-key="39bfb7c3-1a0e-4434-9486-626e30414006" 
      data-api-url="https://hma-chat-bot.vercel.app/api"
      defer
    )
  body.bg-slate-50.text-slate-900
    include ./navbar.pug
    main
      block content
    script(type='module', src='/src/app/main.js')
    block scripts
